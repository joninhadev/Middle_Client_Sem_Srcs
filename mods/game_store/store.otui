    margin-right: 5
    font: verdana-9px
    color: #ffbc3b
    shadow: true
    text-auto-resize: true
    text: 50
    phantom: true

  PointsCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
    anchors.left: price.right

  ItemCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
    anchors.left: price.right

  GoldCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
    anchors.left: price.right

