SmallButton < UIButton
  font: cipsoftFont
  color: #ffffffff
  size: 106 18
  text-offset: 0 3
  image-source: /images/ui/button
  image-clip: 0 0 22 23
  image-border: 3
  padding: 5 10 5 10
  opacity: 1.0
  change-cursor-image: true
  cursor: pointer

  $hover !disabled:
    image-clip: 0 23 22 23

  $pressed:
    image-clip: 0 46 22 23
    text-offset: 1 3

  $disabled:
    color: #ffffff88
    opacity: 0.8
    change-cursor-image: false

CurrencyPanel < Panel
  anchors.bottom: parent.bottom
  image-source: /images/store/backdrop-dark-grey
  image-border: 1
  width: 90
  padding: 2 4

MainWindow
  text: Game Store
  size: 635 500

  StoreTabBar
    id: tabBar
    anchors.top: parent.top
    anchors.left: parent.left

  HorizontalSeparator
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right

  Panel
    id: content
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: bottomSeparator.top

  HorizontalSeparator
    id: bottomSeparator
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: pointsPanel.top
    margin-bottom: 5

  CurrencyPanel
    id: goldPanel
    anchors.left: parent.left

    Label
      id: label
      anchors.verticalCenter: parent.verticalCenter
      anchors.right: parent.right
      margin-right: 14
      text-auto-resize: true
      text: 50,400
      icon: /images/store/gold
      icon-offset-x: 14
      icon-align: right

  CurrencyPanel
    id: itemPanel
    anchors.left: goldPanel.right
    margin-left: 5

    Label
      id: label
      anchors.verticalCenter: parent.verticalCenter
      anchors.right: parent.right
      margin-right: 14
      text-auto-resize: true
      text: 50,400

    UIItem
      id: item
      anchors.verticalCenter: parent.verticalCenter
      anchors.right: parent.right
      margin-right: -12
      size: 32 32
      item-id: 3042
      virtual: true
      phantom: true

  CurrencyPanel
    id: pointsPanel
    anchors.left: itemPanel.right
    margin-left: 5

    Label
      id: label
      anchors.verticalCenter: parent.verticalCenter
      anchors.right: parent.right
      margin-right: 14
      text-auto-resize: true
      text: 50,400
      icon: /images/store/icon-tibiacoin
      icon-offset-x: 14
      icon-align: right

  UIButton
    anchors.left: prev.right
    anchors.bottom: parent.bottom
    size: 60 20
    margin-left: 10
    image-color: #44ff44
    color: white
    text: PIX
    text-offset: -12 1
    icon: /images/store/icon_pix
    icon-offset-x: 12
    image-source: /images/ui/button
    image-clip: 0 0 22 23
    image-border: 3
    padding: 5 10 5 10
    opacity: 1.0
    change-cursor-image: true
    cursor: pointer
    @onClick: modules.game_store.getCoins()

    $hover !disabled:
      image-clip: 0 23 22 23

    $pressed:
      image-clip: 0 46 22 23
      text-offset: -12 1

    $disabled:
      color: #dfdfdf88
      opacity: 0.8
      change-cursor-image: false

  Button
    anchors.left: prev.right
    anchors.bottom: parent.bottom
    size: 60 20
    margin-left: 10
    icon: /images/store/icon-transfercoins
    @onClick: modules.game_store.showGift()

  SmallButton
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    width: 40
    text: Close
    @onClick: modules.game_store.hide()

  SmallButton
    id: history
    anchors.right: prev.left
    anchors.bottom: parent.bottom
    width: 50
    margin-right: 5
    text: History