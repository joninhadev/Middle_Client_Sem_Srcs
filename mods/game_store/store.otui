StoreTabBar < UITabBar
  height: 30
  layout:
    type: horizontalBox
    fit-children: true

  Panel
    id: buttonsPanel
    padding: 5 0
    layout:
      type: horizontalBox
      spacing: 5
      fit-children: true

StoreTabBarPanel < Panel
StoreTabBarButton < UIButton
  height: 20
  padding: 2 5
  background: #00000000
  @onCheckChange: self.label:setOn(self:isChecked())
  layout:
    type: horizontalBox
    spacing: 2
    fit-children: true

  $hover:
    background: #00000033

  Panel
    id: icon
    image-source: /images/store/store-icons-inline
    image-clip: 0 0 13 13
    image-size: 13 13
    width: 13
    margin-top: 3

  Label
    id: label
    border-width-bottom: 0
    border-color-bottom: white
    font: verdana-bold-12px
    color: #bbbbbb

    $on:
      color: white
      border-width-bottom: 1

StoreSideTabBar < UITabBar
  padding-top: 5
  layout:
    type: verticalBox
    fit-children: true

  Panel
    id: buttonsPanel
    layout:
      type: verticalBox
      fit-children: true

StoreSideTabBarPanel < Panel
StoreSideTabBarButton < UIButton
  height: 24
  padding: 4
  background: #00000000
  @onCheckChange: self.label:setOn(self:isChecked())
  layout:
    type: horizontalBox
    spacing: 2

  $hover:
    background: #00000033

  Panel
    id: icon
    image-source: /images/store/store-icons-inline
    image-size: 13 13
    width: 13
    margin-top: 3
  Label
    id: label
    font: verdana-bold-12px
    border-width-bottom: 0
    border-color-bottom: white
    color: #bbbbbb

    $on:
      color: white
      border-width-bottom: 1

StoreSaleFlag < Panel
  anchors.left: parent.left
  anchors.bottom: parent.bottom
  image-source: /images/store/store-flag-sale
  margin: -4

PointsCurrencyIcon < UIWidget
  id: pointsCurrency
  image-source: /images/store/icon-tibiacoin
  margin-left: 2
  phantom: true
  visible: false

ItemCurrencyIcon < UIWidget
  id: itemCurrency
  image-source: /images/store/currency
  margin-left: 2
  phantom: true
  visible: false

GoldCurrencyIcon < UIWidget
  id: goldCurrency
  image-source: /images/store/gold
  margin-left: 4
  phantom: true
  visible: false

StoreBundleEntry < Panel
  image-source: /images/store/panel
  image-border: 3
  padding: 4
  width: 150
  phantom: false
  border-width: 1
  border-color: alpha

  $hover:
    border-color: white

  Panel
    id: previews
    anchors.centerIn: parent
    size: 128 128

    UIWidget
      id: image
      anchors.centerIn: parent
      phantom: true
      visible: false

    Panel
      id: creatures
      anchors.fill: parent
      margin-left: 8

      UICreature
        id: 1
        anchors.top: parent.top
        anchors.left: parent.left
        size: 64 64
        visible: false

      UICreature
        id: 2
        anchors.top: parent.top
        anchors.left: parent.left
        size: 64 64
        margin-top: 16
        margin-left: 32
        visible: false

      UICreature
        id: 3
        anchors.top: parent.top
        anchors.left: parent.left
        size: 64 64
        margin-top: 32
        margin-left: 0
        visible: false

      UICreature
        id: 4
        anchors.top: parent.top
        anchors.left: parent.left
        size: 64 64
        margin-top: 48
        margin-left: 32
        visible: false

    Panel
      id: items
      anchors.fill: parent
      margin-left: 8

      UIItem
        id: 1
        anchors.top: parent.top
        anchors.left: parent.left
        size: 32 32
        margin-top: 24
        margin-left: 24
        virtual: true
        phantom: true
        visible: false

      UIItem
        id: 2
        anchors.top: parent.top
        anchors.left: parent.left
        size: 32 32
        margin-top: 40
        margin-left: 56
        virtual: true
        phantom: true
        visible: false

      UIItem
        id: 3
        anchors.top: parent.top
        anchors.left: parent.left
        size: 32 32
        margin-top: 56
        margin-left: 24
        virtual: true
        phantom: true
        visible: false

      UIItem
        id: 4
        anchors.top: parent.top
        anchors.left: parent.left
        size: 32 32
        margin-top: 72
        margin-left: 56
        virtual: true
        phantom: true
        visible: false

    Panel
      id: images
      anchors.fill: parent

      UIWidget
        id: 1
        anchors.top: parent.top
        anchors.left: parent.left
        visible: false

      UIWidget
        id: 2
        anchors.top: parent.top
        anchors.right: parent.right
        visible: false

      UIWidget
        id: 3
        anchors.bottom: parent.bottom
        anchors.left: parent.left
        visible: false

      UIWidget
        id: 4
        anchors.bottom: parent.bottom
        anchors.right: parent.right
        visible: false

  Label
    id: name
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    text-align: center
    text-auto-resize: true
    font: terminus-14px-bold
    text: Sorcerer Bundle
    color: #ffbc3b
    shadow: true

  Label
    id: price
    anchors.horizontalCenter: parent.horizontalCenter
    anchors.bottom: parent.bottom
    font: verdana-11px-monochrome
    color: #ffbc3b
    shadow: true
    text-auto-resize: true
    margin-right: 5
    margin-bottom: 15

  UIWidget
    anchors.verticalCenter: prev.verticalCenter
    anchors.left: prev.right
    image-source: /images/store/icon-tibiacoin
    margin-left: 3
    phantom: true

  Label
    id: save
    anchors.horizontalCenter: parent.horizontalCenter
    anchors.bottom: parent.bottom
    font: verdana-11px-monochrome
    color: #ffbc3b
    shadow: true
    text-auto-resize: true
    margin-right: 5

  PointsCurrencyIcon
    anchors.verticalCenter: save.verticalCenter
    anchors.left: save.right

  ItemCurrencyIcon
    anchors.verticalCenter: save.verticalCenter
    anchors.left: save.right

  GoldCurrencyIcon
    anchors.verticalCenter: save.verticalCenter
    anchors.left: save.right

  StoreSaleFlag

StoreCreatureSmallEntry < Panel
  image-source: /images/store/panel
  image-border: 3
  padding: 5
  phantom: false
  border-width: 1
  border-color: alpha

  $hover:
    border-color: white

  UICreature
    id: outfit
    anchors.centerIn: parent
    size: 64 64
    phantom: true

  Label
    id: name
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    font: verdana-11px-rounded
    text-align: center
    text-auto-resize: true
    text-wrap: true
    color: #ffbc3b
    phantom: true

  Label
    id: price
    anchors.horizontalCenter: parent.horizontalCenter
    anchors.bottom: parent.bottom
    margin-right: 5
    font: verdana-9px
    color: #ffbc3b
    shadow: true
    text-auto-resize: true
    text: 250
    phantom: true

  PointsCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
    anchors.left: price.right

  ItemCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
    anchors.left: price.right

  GoldCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
    anchors.left: price.right

