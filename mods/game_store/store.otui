StoreImageEntry < Panel
  image-source: /images/store/panel
  image-border: 3
  padding: 5
  phantom: false
  border-width: 1
  border-color: alpha

  $hover:
    border-color: white

  UIWidget
    id: image
    anchors.centerIn: parent
    phantom: true

  Label
    id: name
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    font: verdana-11px-rounded
    text-align: center
    text-auto-resize: true
    text-wrap: true
    color: #ffbc3b
    text: All regular Blessings
    phantom: true

  Label
    id: price
    anchors.horizontalCenter: parent.horizontalCenter
    anchors.bottom: parent.bottom
    margin-right: 5
    font: verdana-9px
    color: #ffbc3b
    shadow: true
    text-auto-resize: true
    text: 130
    phantom: true

  PointsCurrencyIcon
    anchors.verticalCenter: price.verticalCenter
